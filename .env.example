# Обязательные
TG_API_ID=
TG_API_HASH=

# Канал (username без @)
TG_CHANNEL=HouseMiva

# Путь к файлу архива
TG_OUTPUT_FILE=telegram_posts.json

# Первый запуск: сколько последних сообщений загрузить (если TG_FULL_BACKUP=false)
TG_MESSAGE_LIMIT=100

# Первый запуск: загрузить всю историю канала (true/false)
TG_FULL_BACKUP=false

# SOCKS5-прокси (опционально)
TG_PROXY_HOST=
TG_PROXY_PORT=

# Явно включить/выключить прокси (true/false). По умолчанию — включён, если заданы HOST и PORT
TG_PROXY_ENABLED=true

# Повторы при сетевых ошибках (exponential backoff + jitter)
TG_RETRY_COUNT=5
TG_RETRY_MAX_DELAY=60
